# 使用するAIプロバイダーを選択: openai / claude / gemini（デフォルト: openai）
AI_PROVIDER=openai

# OpenAI API設定（AI_PROVIDER=openai の場合に使用）
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude API設定（AI_PROVIDER=claude の場合に使用）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini API設定（AI_PROVIDER=gemini の場合に使用）
GEMINI_API_KEY=your_gemini_api_key_here
